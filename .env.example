# =============================================
# AI Code Review Tool — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# ---- Supabase ----
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- OpenRouter AI ----
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ---- OpenRouter Model (optional) ----
# Default: google/gemini-2.0-flash-001:free
# Other options: anthropic/claude-3-haiku, openai/gpt-4o-mini
OPENROUTER_MODEL=google/gemini-2.0-flash-001:free
